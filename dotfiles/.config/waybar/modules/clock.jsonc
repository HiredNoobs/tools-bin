{
    "clock": {
        "format": "{:%A  靎ｲ  %B-%d-%Y  鞺ｺ  %H:%M:%S %p}",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>",
        "on-click": "hyprctl dispatch exec [float] gnome-calendar",
        "calendar": {
            "format": {
                "today": "<span color='#fb4934'><b>{}</b></span>"
            }
        }
    }
}
