{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#28282890",
                "editor.background": "#28282890",
                "editor.foreground": "#d5c4a1",
                "text": "#d5c4a1",
                "text.muted": "#d5c4a170",
                "text.ignored": "#d5c4a140",
                "text.placeholder": "#d5c4a150",
                "ignored": "#d5c4a130",
                "element.hover": "#d5c4a130",
                "ghost_element.hover": "#fb493430",
                "ghost_element.selected": "#fb493430",
                "ghost_element.active": "#fb493460",
                "border": "#282828",
                "editor.highlighted_line.background": "#fb493410",
                "editor.active_line.background": "#fb493410",
                "panel.background": "#28282890",
                "title_bar.background": "#28282890",
                "title_bar.inactive_background": "#28282890",
                "status_bar.background": "#28282890",
                "drop_target.background": "#28282890",
                "elevated_surface.background": "#282828",
                "toolbar.background": "#28282890",
                "tab_bar.background": "#28282890",
                "tab.inactive_background": "#28282890",
                "tab.active_background": "#fb493430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#282828",
                "scrollbar.thumb.background": "#fb4934",
                "editor.gutter.background": "#28282890",
                "terminal.background": "#28282810",
                "terminal.foreground": "#d5c4a1",
                "terminal.dim_foreground": "#d5c4a1",
                "terminal.bright_foreground": "#d5c4a1",
                "terminal.ansi.black": "#282828",
                "terminal.ansi.red": "#fb4934",
                "terminal.ansi.green": "#b8bb26",
                "terminal.ansi.yellow": "#fabd2f",
                "terminal.ansi.blue": "#83a598",
                "terminal.ansi.magenta": "#d3869b",
                "terminal.ansi.cyan": "#8ec07c",
                "terminal.ansi.white": "#d5c4a1",
                "terminal.ansi.bright_black": "#665c54",
                "terminal.ansi.bright_red": "#fb4934",
                "terminal.ansi.bright_green": "#b8bb26",
                "terminal.ansi.bright_yellow": "#fabd2f",
                "terminal.ansi.bright_blue": "#83a598",
                "terminal.ansi.bright_magenta": "#d3869b",
                "terminal.ansi.bright_cyan": "#8ec07c",
                "terminal.ansi.bright_white": "#fbf1c7",
                "modified": "#fb4934",
                "syntax": {
                    "attribute": {
                        "color": "#fb4934"
                    },
                    "boolean": {
                      "color": "#b8bb26"
                    },
                    "comment": {
                      "color": "#665c54"
                    },
                    "comment.doc": {
                      "color": "#665c54"
                    },
                    "constant": {
                      "color": "#b8bb26"
                    },
                    "function": {
                      "color": "#8ec07c"
                    },
                    "keyword": {
                      "color": "#83a598"
                    },
                    "number": {
                      "color": "#d3869b"
                    },
                    "operator": {
                      "color": "#83a598"
                    },
                    "string": {
                      "color": "#fb4934"
                    },
                    "variable": {
                      "color": "#b8bb26"
                    }
                },
                "players": [
                  {
                    "cursor": "#fb4934",
                    "background": "#282828",
                    "selection": "#fb493430"
                  }
                ]
            }
        }
    ]
}
